# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/passwordless-auth

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Email (Nodemailer) — Ethereal for dev, real SMTP for production
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
EMAIL_FROM=noreply@authguide.dev

# Magic link TTL in minutes
MAGIC_LINK_TTL=10


# Relying Party — your app's identity
RP_NAME=AuthGuide
RP_ID=localhost
# Must match RP_ID origin — no trailing slash
RP_ORIGIN=http://localhost:3001

# Application
CLIENT_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001
ALLOW_MULTI_DEVICE=true
