# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/mfa-auth

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Password hashing
PASSWORD_PEPPER=your-pepper-change-this-in-production

# TOTP settings
TOTP_ISSUER=AuthGuide
TOTP_ALGORITHM=SHA1
TOTP_DIGITS=6
TOTP_PERIOD=30

# Backup codes count
BACKUP_CODES_COUNT=10

# For dev/testing: use Ethereal (https://ethereal.email)
# For production: use real SMTP (SendGrid, SES, etc.)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
EMAIL_FROM=noreply@authguide.dev

# For dev/testing: SMS codes are logged to console
# For production: set Twilio credentials
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
ALLOW_MULTI_DEVICE=true
