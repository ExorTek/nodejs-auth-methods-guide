# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/web3-auth

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7

# Web3 Configuration
# Nonce TTL in minutes
NONCE_TTL=10

# Ethereum RPC (for ENS resolution, NFT checks — optional)
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Solana RPC (for NFT checks — optional)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# NFT Gating — contract addresses (optional)
# ETH_NFT_CONTRACT=0x...
# SOLANA_NFT_COLLECTION=...

# Application
CLIENT_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001
ALLOW_MULTI_DEVICE=true
